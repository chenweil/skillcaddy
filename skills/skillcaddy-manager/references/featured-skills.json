{
  "version": "0.14.1",
  "lastUpdated": "2026-07-17",
  "description": "Skillcaddy 推荐策略和配置指南 (版本与 Skillcaddy 主项目保持一致)",
  "changelog": [
    {
      "version": "0.14.1",
      "date": "2026-07-17",
      "changes": [
        "skillcaddy-manager 按 writing-great-skills 原则重构",
        "引入 Core Loop 作为 leading concept",
        "信息分层到 OPERATIONS/RECOMMENDATION_GUIDE/METADATA",
        "删除冗余的 SUMMARY.md 和 README.md"
      ]
    },
    {
      "version": "0.14.0",
      "date": "2026-07-17",
      "changes": [
        "冲突判断改为基于名称、能力清单和功能描述的相似度候选",
        "移除固定库名冲突规则，最终结论由当前 skill 内容决定",
        "精简 skillcaddy-manager 并按操作、推荐和 metadata 分支披露"
      ]
    },
    {
      "version": "0.9.0",
      "date": "2026-06-29",
      "changes": [
        "优化推荐流程: 先分析 API state 再推荐",
        "新增 onboarding 场景: 空库时推荐发现平台",
        "完善推荐原则: 分析优先、平台优先、场景分层",
        "更新 SKILL.md: 添加推荐流程说明",
        "更新文档: README 和 RECOMMENDATION_GUIDE 同步更新",
        "增加测试: skillStore 测试覆盖"
      ]
    },
    {
      "version": "0.8.0",
      "date": "2026-06-29",
      "changes": [
        "添加完整推荐系统 (references + scripts)",
        "实现目录冲突检测（后续改为相似度候选审查）",
        "实现全局 Skills 检测和建议",
        "实现版本管理和同步",
        "更新 README 文档",
        "优化目录结构,符合 skill 规范"
      ]
    },
    {
      "version": "0.7.0",
      "date": "2026-06-29",
      "changes": [
        "添加全局 Skills 检测功能",
        "添加目录冲突检测逻辑（后续改为相似度候选审查）",
        "优化推荐策略: 少而精,一次最多3个",
        "版本号与 Skillcaddy 主项目同步"
      ]
    }
  ],
  "recommendationStrategy": {
    "principle": "先分析库和项目上下文,再做分层推荐;平台优先,场景分流,最后补短板",
    "maxRecommendations": 3,
    "notes": [
      "推荐要精准,避免选择困难",
      "空库时先给平台入口,不要默认塞具体库",
      "只有明确开发场景时,才把 mattpocock 作为 starter 候选",
      "已有库时优先补短板,不要重复推荐同类能力"
    ]
  },
  "recommendationModes": {
    "discovery": {
      "label": "发现入口",
      "when": "用户库为空,或暂时无法判断用户主要场景",
      "goal": "先帮助用户浏览平台和分类,不要直接推默认库",
      "recommend": [
        "skillsmp",
        "skills-sh"
      ]
    },
    "starter": {
      "label": "场景起步库",
      "when": "能从当前项目、已有 skill、用户需求判断出明确场景",
      "goal": "只推荐 1 个 starter 库,必要时再加 1 个质量控制库"
    },
    "gap-based": {
      "label": "补短板推荐",
      "when": "用户已经有一些 skills,需要继续扩展能力",
      "goal": "先识别已有能力分布,再补缺失类别,避免重复"
    }
  },
  "analysisSignals": {
    "development": [
      "当前项目是代码仓库",
      "已有 coding-protocol / keel / tdd / debugging 类 skills",
      "用户明确提到开发、重构、测试、调试"
