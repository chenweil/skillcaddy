{
  "name": "skillcaddy",
  "version": "0.12.0",
  "private": true,
  "description": "Local skill source library and per-project symlink manager.",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "test": "node --test test/*.test.js && npm run lint:imports",
    "test:unit": "node --test test/*.test.js",
    "lint:imports": "node scripts/check-imports.js",
    "lint": "node scripts/check-imports.js",
    "install:manager": "node scripts/manager-skill.js install",
    "check:manager": "node scripts/manager-skill.js check",
    "pull:github": "bash scripts/pull-github.sh",
    "tui": "node scripts/tui.js"
  },
  "engines": {
    "node": ">=20"
  }
}
